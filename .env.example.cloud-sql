# .env.example - Environment Variables for Firebase + Cloud SQL

# ========================================
# FIREBASE AUTHENTICATION & CONFIGURATION
# ========================================

# Get these from Firebase Console → Project Settings → Service Accounts
VITE_FIREBASE_API_KEY=AIzaSyD_1234567890abcdefghijklmnopqr_stub
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890stub

# ========================================
# CLOUD SQL CONNECTION (PostgreSQL)
# ========================================

# Instance connection name from Cloud SQL overview
# Format: PROJECT_ID:REGION:INSTANCE_NAME
DB_INSTANCE=my-project:us-central1:qa-generator-db

# Connection host - use Unix socket for Cloud Functions (secure)
# For local development: localhost
# For Cloud Functions: /cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DB_HOST=/cloudsql/my-project:us-central1:qa-generator-db

# Database connection user (created in Cloud SQL)
DB_USER=qa_app

# Database password (from Cloud SQL user creation)
# Keep this secret! Don't commit to git
DB_PASSWORD=your_secure_password_here_change_me

# Database name
DB_NAME=qa_generator

# Database port (always 5432 for PostgreSQL)
DB_PORT=5432

# ========================================
# COMPLETE CONNECTION STRINGS (Optional)
# ========================================

# For direct TCP connection (less secure, use only for development)
DATABASE_URL=postgresql://qa_app:your_password@localhost:5432/qa_generator

# For Cloud SQL Proxy with Unix socket
DATABASE_URL_SOCKET=postgresql://qa_app:your_password@/qa_generator?host=/cloudsql/my-project:us-central1:qa-generator-db

# With SSL (production recommended)
DATABASE_URL_SSL=postgresql://qa_app:your_password@db.example.com:5432/qa_generator?sslmode=require

# ========================================
# DEVELOPMENT SETTINGS
# ========================================

# Enable React dev server with hot reload
VITE_DEV_SERVER_PORT=5173

# Firebase Emulator Settings (for local development)
# Set to true to use Firebase Emulator Suite locally
VITE_USE_FIREBASE_EMULATOR=false

# Functions Emulator
FIREBASE_FUNCTIONS_EMULATOR_HOST=localhost:5001

# ========================================
# PRODUCTION SETTINGS
# ========================================

# Set different values in production deployment
NODE_ENV=development

# API endpoints (if you have a backend API)
VITE_API_URL=http://localhost:3000/api

# Firebase Analytics
VITE_ENABLE_ANALYTICS=false

# ========================================
# SENSITIVE - NEVER COMMIT
# ========================================

# Service Account Key (for backend only, never in React!)
# Get from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# FIREBASE_SERVICE_ACCOUNT_KEY_FILE=./config/firebase-adminsdk.json

# Database Admin User (for database maintenance only)
# DB_ADMIN_USER=postgres
# DB_ADMIN_PASSWORD=postgres_admin_password

# ========================================
# NOTES
# ========================================

# 1. FIREBASE_API_KEY is public - it's used in frontend
# 2. DB_PASSWORD should only be in .env.local for local dev
# 3. In production, use secrets management (Google Secret Manager)
# 4. For Cloud Functions, set env vars in Firebase Console Runtime Settings
# 5. Never use "postgres" user in production - use app-specific role

# ========================================
# EXAMPLE USAGE
# ========================================

# Development:
# - Copy to .env.local
# - Replace values with your actual credentials
# - Start with: npm run dev

# Production:
# - Set environment variables in cloud deployment (Firebase Console, Vercel, etc.)
# - Use secret management for sensitive values
# - Test with: firebase emulators:start

# Cloud Functions Deployment:
# firebase functions:config:set cloudsql.instance="PROJECT:REGION:INSTANCE"
# firebase functions:config:set cloudsql.user="qa_app"
# firebase functions:config:set cloudsql.password="YOUR_PASSWORD"
# firebase functions:config:set cloudsql.database="qa_generator"

# ========================================
# GETTING VALUES
# ========================================

# Find Firebase config:
# 1. Firebase Console
# 2. Project Settings (gear icon)
# 3. Service Accounts Tab
# 4. Click "Get Config Snippet" or use initialized SDK

# Find Cloud SQL connection info:
# 1. Google Cloud Console
# 2. Cloud SQL Instances
# 3. Click your instance
# 4. Overview tab shows connection details
# 5. Instance connection name: PROJECT_ID:REGION:INSTANCE_NAME

# Create Cloud SQL user:
# gcloud sql users create qa_app --instance=qa-generator-db --password
# OR in Cloud SQL Console → Users

# ========================================
# TROUBLESHOOTING
# ========================================

# Environment variables not loading?
# 1. Restart dev server: npm run dev
# 2. Check .env.local exists (not .env)
# 3. Verify no spaces around =
# 4. Use VITE_ prefix for frontend variables
# 5. For backend: use process.env.DB_PASSWORD directly

# Can't connect to database?
# 1. Test credentials: gcloud sql connect qa-generator-db
# 2. Check instance is running (green checkmark in Cloud Console)
# 3. Check user exists: \du in psql
# 4. Check database exists: \l in psql
# 5. Check permissions: GRANT SELECT ON products TO qa_app;
